<Window x:Class="idk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:idk"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Background="#FF343434" RenderTransformOrigin="0.496,0.5">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="Auto" MinHeight="209"/>
            <RowDefinition Height="Auto" MinHeight="143.04"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Button x:Name="GoButton" Content="GO!" HorizontalAlignment="Left" Margin="422,0,0,0" VerticalAlignment="Bottom" Height="60" Width="103" Grid.Row="2" Grid.RowSpan="2" Click="GoButton_Click"/>
        <Button x:Name="StartButton" Content="START" HorizontalAlignment="Left" Margin="247,0,0,0" VerticalAlignment="Center" Height="60" Width="103" Grid.Row="3" Click="StartButton_Click"/>
        <Ellipse x:Name="_1" HorizontalAlignment="Left" Height="106" Margin="219,0,0,0" Grid.Row="1" Stroke="#555" Fill="#3a0000" VerticalAlignment="Center" Width="122"/>
        <Ellipse x:Name="_2" HorizontalAlignment="Left" Height="106" Grid.Row="1" Stroke="#555" Fill="#3a0000" VerticalAlignment="Center" Width="122" Margin="341,0,0,0"/>
        <Ellipse x:Name="_3" HorizontalAlignment="Left" Height="106" Margin="463,0,0,0" Grid.Row="1" Stroke="#555" Fill="#3a0000" VerticalAlignment="Center" Width="122"/>
        <Ellipse x:Name="_4" HorizontalAlignment="Left" Height="106" Margin="585,0,0,0" Grid.Row="1" Stroke="#555" Fill="#3a0000" VerticalAlignment="Center" Width="122"/>
        <Ellipse x:Name="_0" HorizontalAlignment="Left" Height="106" Margin="97,0,0,0" Grid.Row="1" Stroke="#555" Fill="#3a0000" VerticalAlignment="Center" Width="122"/>
        <StackPanel x:Name="StackPanel" HorizontalAlignment="Center" Height="144" Grid.Row="1" VerticalAlignment="Center" Width="686"/>
        <TextBlock x:Name="TimerLabel" HorizontalAlignment="Left" Height="80" Margin="328,34,0,0" Grid.Row="2" TextWrapping="Wrap" VerticalAlignment="Top" Width="318" FontSize="35" Text="---.---   s" Foreground="#FFFDFDFD"/>

    </Grid>
</Window>
