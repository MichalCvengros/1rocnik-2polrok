<Window x:Class="GunShop.Shop"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GunShop"
        mc:Ignorable="d"
        Title="Shop" Height="450" Width="800">
    <Grid>
        <ListBox x:Name="ShopList" HorizontalAlignment="Left" Height="369" Margin="52,25,0,0" VerticalAlignment="Top" Width="209" d:ItemsSource="{d:SampleData ItemCount=5}"/>
        <Button x:Name="CartBtn" Content="CART" HorizontalAlignment="Left" Height="47" Margin="400,347,0,0" VerticalAlignment="Top" Width="75" Click="CartBtn_Click"/>
        <Button x:Name="BackBtn" Content="BACK" HorizontalAlignment="Left" Height="47" Margin="502,347,0,0" VerticalAlignment="Top" Width="75" Click="BackBtn_Click"/>

    </Grid>
</Window>
