<Window x:Class="GunShop.Cart"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GunShop"
        mc:Ignorable="d"
        Title="Cart" Height="450" Width="800">
    <Grid>
        <ListBox x:Name="CartList" HorizontalAlignment="Left" Height="376" VerticalAlignment="Center" Width="207" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="47,0,0,0"/>
        <Button x:Name="BackBtn" Content="BACK" HorizontalAlignment="Left" Height="51" Margin="400,203,0,0" VerticalAlignment="Top" Width="82" Click="BackBtn_Click"/>
        <Button x:Name="BuyBtn" Content="Buy" HorizontalAlignment="Left" Height="51" Margin="543,203,0,0" VerticalAlignment="Top" Width="94" Click="BuyBtn_Click"/>

    </Grid>
</Window>
