<Window x:Class="GunShop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GunShop"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid x:Name="AdminGrid">
        <ListBox x:Name="GunList" HorizontalAlignment="Left" Height="384" VerticalAlignment="Center" Width="236" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="50,0,0,0"/>
        <Button x:Name="ShopBtn" Content="SHOP" HorizontalAlignment="Left" Height="54" Margin="437,280,0,0" VerticalAlignment="Top" Width="109" Click="ShopBtn_Click"/>
        <TextBox x:Name="GunText" HorizontalAlignment="Left" Height="42" Margin="374,148,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="118"/>
        <Button x:Name="AddBtn" Content="ADD" HorizontalAlignment="Left" Height="42" Margin="542,148,0,0" VerticalAlignment="Top" Width="74" Click="AddBtn_Click"/>

    </Grid>
</Window>
