<Window x:Class="KoncTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KoncTest"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <ComboBox x:Name="Auta" HorizontalAlignment="Left" Height="40" Margin="39,68,0,0" VerticalAlignment="Top" Width="142" SelectionChanged="Auta_SelectionChanged">
            <ComboBoxItem Content="CA-123AB(0,42$/km)"/>
            <ComboBoxItem Content="AA-987BC(0,36$/km)"/>
            <ComboBoxItem Content="ZA-568HD(0,25$/km)"/>
        </ComboBox>
        <TextBlock x:Name="KMTextBlock" HorizontalAlignment="Left" Height="32" Margin="194,76,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="104" Text="Stav km"/>
        <Label Content="Pociatocny stav km:" HorizontalAlignment="Left" Height="35" Margin="186,36,0,0" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="AddKMTextBox" HorizontalAlignment="Left" Height="32" Margin="453,75,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="110"/>
        <Button x:Name="AddKmBtn" Content="Pridat jazdu" HorizontalAlignment="Left" Height="37" Margin="583,70,0,0" VerticalAlignment="Top" Width="106" Click="AddKmBtn_Click"/>
        <ListBox x:Name="SPZList" HorizontalAlignment="Left" Height="119" Margin="199,259,0,0" VerticalAlignment="Top" Width="104" d:ItemsSource="{d:SampleData ItemCount=5}"/>
        <ListBox x:Name="StartKM" HorizontalAlignment="Left" Height="119" Margin="303,259,0,0" VerticalAlignment="Top" Width="104" d:ItemsSource="{d:SampleData ItemCount=5}"/>
        <ListBox x:Name="FinalKM" HorizontalAlignment="Left" Height="119" Margin="407,259,0,0" VerticalAlignment="Top" Width="104" d:ItemsSource="{d:SampleData ItemCount=5}"/>
        <ListBox x:Name="NajazdeneKM" HorizontalAlignment="Left" Height="119" Margin="511,259,0,0" VerticalAlignment="Top" Width="104" d:ItemsSource="{d:SampleData ItemCount=5}"/>
        <Label Content="SPZ" HorizontalAlignment="Left" Height="37" Margin="224,217,0,0" VerticalAlignment="Top" Width="54"/>
        <Label Content="Pociatocne KM" HorizontalAlignment="Left" Height="36" Margin="308,218,0,0" VerticalAlignment="Top" Width="92"/>
        <Label Content="Koncove KM" HorizontalAlignment="Left" Height="37" Margin="424,217,0,0" VerticalAlignment="Top" Width="80"/>
        <Label Content="Najazdene KM" HorizontalAlignment="Left" Height="37" Margin="520,217,0,0" VerticalAlignment="Top" Width="86"/>
        <ListBox x:Name="CelkovaCena" HorizontalAlignment="Left" Height="119" Margin="615,259,0,0" VerticalAlignment="Top" Width="104" d:ItemsSource="{d:SampleData ItemCount=5}"/>
        <Label Content="Celkova cena" HorizontalAlignment="Left" Height="37" Margin="624,217,0,0" VerticalAlignment="Top" Width="86"/>

    </Grid>
</Window>
