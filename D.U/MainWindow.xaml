<Window x:Class="D.U_.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:D.U_"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <TextBox x:Name="Add_Student_Box" HorizontalAlignment="Left" Height="19" Margin="10,50,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="138" Text="Napis meno žiaka"/>
        <Button x:Name="Add_Student_Btn" Content="Pridať žiaka" HorizontalAlignment="Left" Height="19" Margin="170,50,0,0" VerticalAlignment="Top" Width="71" Click="Add_Student_Btn_Click"/>
        <ListBox x:Name="Student_ListView" HorizontalAlignment="Left" Height="259" Margin="10,91,0,0" VerticalAlignment="Top" Width="173" d:ItemsSource="{d:SampleData ItemCount=5}" SelectionChanged="Student_ListView_SelectionChanged"/>
        <Button x:Name="Remove_Student_Btn" Content="Odstraniť žiaka" HorizontalAlignment="Left" Height="21" Margin="10,374,0,0" VerticalAlignment="Top" Width="104" Click="Remove_Student_Btn_Click"/>
        <TextBlock x:Name="Student_View_Box" HorizontalAlignment="Left" Height="16" Margin="206,138,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="132" Text="Meno"/>
        <TextBlock HorizontalAlignment="Left" Height="22" Margin="206,171,0,0" TextWrapping="Wrap" Text="Vyber znamku:" VerticalAlignment="Top" Width="82"/>
        <ComboBox x:Name="AddGrade" HorizontalAlignment="Left" Height="34" Margin="288,171,0,0" VerticalAlignment="Top" Width="56">
            <Button Content="1"/>
            <Button Content="2"/>
            <Button Content="3"/>
            <Button Content="4"/>
            <Button Content="5"/>
        </ComboBox>
        <ListBox x:Name="StudentsGrades" HorizontalAlignment="Left" Height="130" Margin="194,210,0,0" VerticalAlignment="Top" Width="139" d:ItemsSource="{d:SampleData ItemCount=5}"/>
        <Button x:Name="AddGrade_Btn" Content="Pridaj znamku" HorizontalAlignment="Center" Height="23" Margin="0,182,0,0" VerticalAlignment="Top" Width="82" Click="AddGrade_Btn_Click"/>
        <TextBlock HorizontalAlignment="Left" Height="23" Margin="338,222,0,0" TextWrapping="Wrap" Text="Pocet znamok:" VerticalAlignment="Top" Width="88"/>
        <TextBlock HorizontalAlignment="Left" Height="22" Margin="338,264,0,0" TextWrapping="Wrap" Text="Priemer:" VerticalAlignment="Top" Width="77"/>
        <TextBlock x:Name="PocetZnamok" HorizontalAlignment="Left" Height="23" Margin="431,221,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="38"/>
        <TextBlock x:Name="PriemerZnamok" HorizontalAlignment="Left" Height="24" Margin="415,262,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="47"/>
        <Button x:Name="SaveBtn" Content="SAVE" HorizontalAlignment="Left" Height="21" Margin="194,374,0,0" VerticalAlignment="Top" Width="82" Click="SaveBtn_Click"/>

    </Grid>
</Window>
