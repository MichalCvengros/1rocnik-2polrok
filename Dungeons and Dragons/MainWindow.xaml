<Window x:Class="Dungeons_and_Dragons.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Dungeons_and_Dragons"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Label Content="" HorizontalAlignment="Center" Height="414" VerticalAlignment="Center" Width="400">
            <Label.Background>
                <ImageBrush ImageSource="/dragon-black-and-white-silhouette-illustration-free-vector.jpg"/>
            </Label.Background>
        </Label>
        <TextBlock Grid.Column="1" HorizontalAlignment="Left" Height="30" Margin="10,17,0,0" TextWrapping="Wrap" Text="Character Name:" VerticalAlignment="Top" Width="63"/>
        <TextBox Grid.Column="1" HorizontalAlignment="Left" Height="24" Margin="73,21,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="117"/>
        <TextBlock Grid.Column="1" HorizontalAlignment="Left" Height="32" Margin="222,17,0,0" TextWrapping="Wrap" Text="Level &amp; Class:" VerticalAlignment="Top" Width="68"/>
        <TextBox Grid.Column="1" HorizontalAlignment="Left" Height="28" Margin="290,21,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="95"/>
        <TextBlock Grid.Column="1" HorizontalAlignment="Left" Height="30" Margin="10,94,0,0" TextWrapping="Wrap" Text="Max HitPoints:" VerticalAlignment="Top" Width="63"/>
        <TextBlock Grid.Column="1" HorizontalAlignment="Left" Height="13" Margin="222,102,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="68" Text="Race:"/>
        <TextBox Grid.Column="1" HorizontalAlignment="Left" Height="28" Margin="290,98,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="95"/>
        <TextBox x:Name="StrengthScore" Grid.Column="1" HorizontalAlignment="Left" Height="24" Margin="73,185,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="59" TextChanged="StrengthScore_TextChanged"/>
        <TextBlock Grid.Column="1" HorizontalAlignment="Left" Height="24" Margin="10,185,0,0" TextWrapping="Wrap" Text="Strength:" VerticalAlignment="Top" Width="63"/>
        <TextBlock Grid.Column="1" HorizontalAlignment="Left" Height="24" Margin="10,277,0,0" TextWrapping="Wrap" Text="Dexterity:" VerticalAlignment="Top" Width="63"/>
        <TextBox x:Name="StrengthModifier" Grid.Column="1" HorizontalAlignment="Left" Height="24" Margin="146,185,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="44"/>
        <TextBox Grid.Column="1" HorizontalAlignment="Left" Height="24" Margin="72,348,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="60"/>
        <TextBox Grid.Column="1" HorizontalAlignment="Left" Height="24" Margin="146,277,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="44"/>
        <TextBlock Grid.Column="1" HorizontalAlignment="Left" Height="24" Margin="10,348,0,0" TextWrapping="Wrap" Text="Charisma:" VerticalAlignment="Top" Width="63"/>
        <TextBox Grid.Column="1" HorizontalAlignment="Left" Height="24" Margin="73,277,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="59"/>
        <TextBox Grid.Column="1" HorizontalAlignment="Left" Height="24" Margin="146,348,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="44"/>
        <TextBox Grid.Column="1" HorizontalAlignment="Left" Height="24" Margin="73,102,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="117"/>
        <Button x:Name="d6" Grid.Column="1" Content="d6" HorizontalAlignment="Left" Margin="274,252,0,0" VerticalAlignment="Top" Width="40" Click="d6_Click_1"/>
        <Button x:Name="d8" Grid.Column="1" Content="d8" HorizontalAlignment="Left" Margin="274,289,0,0" VerticalAlignment="Top" Width="40" Click="d8_Click_1"/>
        <Button x:Name="d20" Grid.Column="1" Content="d20" HorizontalAlignment="Left" Margin="274,391,0,0" VerticalAlignment="Top" Width="40" Click="d20_Click"/>
        <Button x:Name="d12" Grid.Column="1" Content="d12" HorizontalAlignment="Left" Margin="274,357,0,0" VerticalAlignment="Top" Width="40" Click="d12_Click"/>
        <Button x:Name="d10" Grid.Column="1" Content="d10" HorizontalAlignment="Left" Margin="274,323,0,0" VerticalAlignment="Top" Width="40" Click="d10_Click"/>
        <Button x:Name="d4" Grid.Column="1" Content="d4" HorizontalAlignment="Left" Margin="274,217,0,0" VerticalAlignment="Top" Width="40" Click="d4_Click"/>
        <Label x:Name="d10Zapis" Grid.Column="1" Content="" HorizontalAlignment="Left" Margin="338,320,0,0" VerticalAlignment="Top" Height="28" Width="30"/>
        <Label x:Name="d12Zapis" Grid.Column="1" Content="" HorizontalAlignment="Left" Margin="338,354,0,0" VerticalAlignment="Top" Height="28" Width="30"/>
        <Label x:Name="d20Zapis" Grid.Column="1" Content="" HorizontalAlignment="Left" Margin="338,388,0,0" VerticalAlignment="Top" Height="28" Width="30"/>
        <Label x:Name="d6Zapis" Grid.Column="1" Content="" HorizontalAlignment="Left" Margin="338,249,0,0" VerticalAlignment="Top" Height="28" Width="30"/>
        <Label x:Name="d8Zapis" Grid.Column="1" Content="" HorizontalAlignment="Left" Margin="338,286,0,0" VerticalAlignment="Top" Height="28" Width="30"/>
        <Label x:Name="d4Zapis" Grid.Column="1" Content="" HorizontalAlignment="Left" Margin="338,214,0,0" VerticalAlignment="Top" Height="28" Width="30"/>
    </Grid>
</Window>
