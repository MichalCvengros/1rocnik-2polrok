<Window x:Class="FakeAlmostIG.Chat"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FakeAlmostIG"
        mc:Ignorable="d"
        Title="Chat" Height="450" Width="800">
    <Grid>
        <ListView x:Name="ChatList" HorizontalAlignment="Left" Height="360" Margin="42,0,0,0" VerticalAlignment="Center" Width="294" d:ItemsSource="{d:SampleData ItemCount=5}">
            <ListView.View>
                <GridView>
                    <GridViewColumn/>
                </GridView>
            </ListView.View>
        </ListView>
        <TextBox x:Name="ChatBox" HorizontalAlignment="Left" Height="118" Margin="468,54,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="258"/>
        <Button x:Name="SendBtn" Content="Send message" HorizontalAlignment="Left" Height="67" Margin="522,217,0,0" VerticalAlignment="Top" Width="150" Click="SendBtn_Click"/>

    </Grid>
</Window>
